{
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron-return-expired-leads",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron-overdue-appointments",
      "schedule": "15 17 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/logo.png",
      "destination": "/brand/logo.png"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/tin-tuc/:slug",
      "destination": "/api/blog-page?slug=:slug"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/login/",
      "destination": "/login.html"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
