# --- Firebase (client / public — an toan de lo, day la cau hinh web) ---
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Danh sach email duoc coi la admin (phan tach bang dau phay)
VITE_ADMIN_EMAILS=admin@example.com

# Cloudinary (neu dung upload media)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Server-only (KHONG dat tien to VITE_ — chi dung trong /api functions) ---
# Dat cac bien nay trong Vercel > Project > Settings > Environment Variables.
ADMIN_PASSWORD=
ADMIN_EMAILS=
REQUIRE_APP_CHECK=false
CRON_SECRET=

# Meta Conversions API
VITE_META_PIXEL_ID=
VITE_META_BROWSER_PIXEL_ENABLED=true
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CAPI_MODE=test
META_GRAPH_VERSION=v25.0
META_CAPI_ENABLED=true
META_CAPI_TIMEOUT_MS=8000
META_SEND_LEAD=true
META_SEND_QUALIFIED_LEAD=true
META_SEND_INITIATE_CHECKOUT=true
META_SEND_PURCHASE=true
META_SEND_LEAD_FAILED=false
META_ALLOW_MANUAL_EVENTS=false

# Meta Lead Ads inbound webhook
META_LEAD_WEBHOOK_VERIFY_TOKEN=
META_LEAD_PAGE_ACCESS_TOKEN=
META_LEAD_GRAPH_VERSION=v25.0

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Vercel Blob public CMS snapshot
BLOB_READ_WRITE_TOKEN=

# LMS enrollment sync
LMS_API_BASE_URL=
LMS_ENROLLMENT_PATH=/api/enrollments
LMS_API_KEY=
LMS_AUTH_HEADER=Authorization
LMS_AUTH_SCHEME=Bearer
LMS_WEBHOOK_SECRET=
LMS_TIMEOUT_MS=12000
VITE_ENABLE_LMS_SYNC_DEV=false

# Stringee Call Center (server-only; KHONG dat tien to VITE_ cho SID/secret)
STRINGEE_API_SID=
STRINGEE_API_SECRET=
STRINGEE_SIGNING_SECRET=
STRINGEE_PROJECT_ID=
STRINGEE_FROM_NUMBER=842488921797
CALL_FALLBACK_AGENT_ID=
CALL_FALLBACK_AGENT_NAME=
PUBLIC_APP_URL=https://your-domain.com
# Recording proxy is always protected by Firebase role checks (admin/manager only).
REQUIRE_RECORDING_AUTH=true
CALL_LOCK_TTL_MS=1800000
CALL_RINGING_LOCK_TTL_MS=300000

# Optional SDK override cho frontend softphone
VITE_STRINGEE_SDK_URL=
