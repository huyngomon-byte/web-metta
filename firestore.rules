rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdminEmail() {
      return signedIn()
        && request.auth.token.email in [
          "admin@mettaacademy.vn",
          "huyngomon@gmail.com",
          "huyngomon999@gmail.com"
        ];
    }

    function hasUserDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function activeUser() {
      return hasUserDoc() && userData().active == true;
    }

    function role() {
      return activeUser() ? userData().role : request.auth.token.role;
    }

    function isAdmin() {
      return bootstrapAdminEmail() || role() == "admin";
    }

    function isManager() {
      return activeUser() && role() == "manager";
    }

    function isSales() {
      return activeUser() && role() == "sales";
    }

    function isAds() {
      return activeUser() && role() == "ads";
    }

    function isDesign() {
      return activeUser() && role() == "design";
    }

    function canManageCms() {
      return isAdmin() || isManager() || isDesign();
    }

    function canManageMarketing() {
      return isAdmin() || isManager() || isAds();
    }

    function canManageLeads() {
      return isAdmin() || isManager();
    }

    function canManageLeadAppConfig(id) {
      return (id == "leadCenterConfigs" || id == "leadSourceConfigs" || id == "salesAssignmentRules")
        && canManageLeads();
    }

    function canReadLeadAppConfig(id) {
      return canManageLeadAppConfig(id)
        || (activeUser() && (id == "leadCenterConfigs" || id == "leadSourceConfigs"));
    }

    function canManageMarketingAppConfig(id) {
      return id == "sourceEngineState" && canManageMarketing();
    }

    function assignmentExpiresAtMs(data) {
      return data.keys().hasAny(["assignedExpiresAtMs"]) && data.assignedExpiresAtMs != 0
        ? data.assignedExpiresAtMs
        : data.keys().hasAny(["assignedAtMs"]) && data.assignedAtMs != 0
          ? data.assignedAtMs + 86400000
          : 0;
    }

    function assignmentReadable(data) {
      return data.assignedStatus == "accepted"
        || (data.assignedStatus == "active" && assignmentExpiresAtMs(data) > request.time.toMillis());
    }

    function salesCanReadLead(data) {
      return isSales()
        && data.assignedTo == request.auth.uid;
    }

    function salesCanWorkLead(data) {
      return salesCanReadLead(data)
        && assignmentReadable(data);
    }

    function salesCanCreateLead() {
      return isSales()
        && request.resource.data.assignedTo == request.auth.uid
        && request.resource.data.assignedBy == request.auth.uid
        && request.resource.data.assignedStatus == "accepted";
    }

    function salesProtectedAssignmentFieldsUnchanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny([
          "assignedTo",
          "assignedToName",
          "assignedBy",
          "assignedAt",
          "assignedAtMs",
          "assignedExpiresAtMs",
          "failedAssignedTo",
          "failedAssignedToName",
          "failedAt",
          "failedAtMs",
          "failedReason"
        ])
        && (
          !changed.hasAny(["assignedStatus"])
          || (resource.data.assignedStatus == "active" && request.resource.data.assignedStatus == "accepted")
        );
    }

    function salesCanUpdateLead() {
      return salesCanWorkLead(resource.data)
        && salesProtectedAssignmentFieldsUnchanged();
    }

    function canReadLeadDoc(data) {
      return canManageLeads() || salesCanReadLead(data);
    }

    function hasCallLead(data) {
      return data.leadId is string && data.leadId != "";
    }

    function salesCanReadCallLog(data) {
      return isSales()
        && (
          data.agentId == request.auth.uid
          || (hasCallLead(data)
            && exists(/databases/$(database)/documents/leads/$(data.leadId))
            && canReadLeadDoc(get(/databases/$(database)/documents/leads/$(data.leadId)).data))
        );
    }

    function salesCanWriteCallLog(data) {
      return isSales()
        && (
          data.agentId == request.auth.uid
          || (hasCallLead(data)
            && exists(/databases/$(database)/documents/leads/$(data.leadId))
            && salesCanReadLead(get(/databases/$(database)/documents/leads/$(data.leadId)).data))
        );
    }

    function callLogLeadUnchanged() {
      return (!hasCallLead(resource.data) && !hasCallLead(request.resource.data))
        || (hasCallLead(resource.data)
          && hasCallLead(request.resource.data)
          && request.resource.data.leadId == resource.data.leadId);
    }

    function publicLeadCreate() {
      return request.auth == null
        && request.resource.data.fullName is string
        && request.resource.data.phone is string
        && request.resource.data.assignedTo == ""
        && request.resource.data.assignedStatus == "unassigned"
        && request.resource.data.source in ["Website", "Landing Page"];
    }

    match /pages/{id} {
      allow read: if resource.data.status == "published" || canManageCms();
      allow create, update, delete: if canManageCms();
    }

    match /pageSections/{id} {
      allow read: if canManageCms()
        || get(/databases/$(database)/documents/pages/$(resource.data.pageId)).data.status == "published";
      allow create, update, delete: if canManageCms();
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow create, update, delete: if canManageCms();
    }

    match /cms_meta/{id} {
      allow read: if true;
      allow create, update, delete: if canManageCms();
    }

    match /media/{id} {
      allow read: if true;
      allow create, update, delete: if canManageCms();
    }

    match /blogPosts/{id} {
      allow read: if true;
      allow create, update, delete: if canManageCms();
    }

    match /leads/{id} {
      allow read: if canReadLeadDoc(resource.data);
      allow create: if canManageLeads() || salesCanCreateLead() || publicLeadCreate();
      allow update: if canManageLeads() || salesCanUpdateLead();
      allow delete: if canManageLeads();
    }

    match /leadActivities/{id} {
      allow read: if canManageLeads()
        || (isSales()
          && canReadLeadDoc(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data));
      allow create: if canManageLeads()
        || (isSales()
          && canReadLeadDoc(get(/databases/$(database)/documents/leads/$(request.resource.data.leadId)).data));
      allow update, delete: if canManageLeads();
    }

    match /appNotifications/{id} {
      allow read: if canManageLeads()
        || (activeUser() && resource.data.userId == request.auth.uid);
      allow create: if canManageLeads();
      allow update: if canManageLeads()
        || (activeUser()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId);
      allow delete: if canManageLeads()
        || (activeUser() && resource.data.userId == request.auth.uid);
    }

    match /appointments/{id} {
      allow read: if canManageLeads()
        || (isSales() && resource.data.assignedTo == request.auth.uid);
      allow create: if canManageLeads()
        || (isSales() && request.resource.data.assignedTo == request.auth.uid);
      allow update: if canManageLeads()
        || (isSales()
          && resource.data.assignedTo == request.auth.uid
          && request.resource.data.assignedTo == resource.data.assignedTo);
      allow delete: if canManageLeads();
    }

    match /parentProfiles/{id} {
      allow read, create, update, delete: if canManageLeads();
    }

    match /appConfig/{id} {
      allow read: if canReadLeadAppConfig(id) || canManageMarketingAppConfig(id);
      allow create, update, delete: if canManageLeadAppConfig(id) || canManageMarketingAppConfig(id);
    }

    match /callCenterSettings/{id} {
      allow read: if activeUser();
      allow create, update, delete: if canManageLeads();
    }

    match /callLogs/{id} {
      allow read: if canManageLeads() || salesCanReadCallLog(resource.data);
      allow create: if canManageLeads()
        || salesCanWriteCallLog(request.resource.data);
      allow update: if canManageLeads()
        || (salesCanWriteCallLog(resource.data)
          && salesCanWriteCallLog(request.resource.data)
          && callLogLeadUnchanged());
      allow delete: if canManageLeads();
    }

    match /agentPresence/{id} {
      allow read: if activeUser();
      allow create, update: if canManageLeads() || (activeUser() && id == request.auth.uid);
      allow delete: if canManageLeads();
    }

    match /salesManualTasks/{id} {
      allow read: if canManageLeads()
        || (isSales() && resource.data.assignedTo == request.auth.uid);
      allow create: if canManageLeads()
        || (isSales() && request.resource.data.assignedTo == request.auth.uid);
      allow update: if canManageLeads()
        || (isSales()
          && resource.data.assignedTo == request.auth.uid
          && request.resource.data.assignedTo == resource.data.assignedTo);
      allow delete: if canManageLeads()
        || (isSales() && resource.data.assignedTo == request.auth.uid);
    }

    match /capiSettings/{id} {
      allow read, write: if canManageMarketing();
    }

    match /capiMappings/{id} {
      allow read, write: if canManageMarketing();
    }

    match /capiEvents/{id} {
      allow read, write: if canManageMarketing();
    }

    match /capiSignalLedger/{id} {
      allow read, write: if canManageMarketing();
    }

    match /activityLogs/{id} {
      allow read, create: if isAdmin() || isManager();
      allow update, delete: if isAdmin();
    }

    match /users/{id} {
      allow read: if activeUser() || bootstrapAdminEmail();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
